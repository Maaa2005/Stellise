<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- トラッキング(ATT対象の広告目的追跡)は行わない -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- 収集データ: 自作サーバ(タスク提案・天気・経路API)へ送信する項目。
	     すべてアプリ機能目的・匿名アカウントのため個人と紐付けなし・トラッキング利用なし -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<!-- 位置情報(おおよそ: kCLLocationAccuracyReduced) — 天気・経路計算 -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeCoarseLocation</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- その他ユーザーコンテンツ — カレンダー予定のタイトル/時刻・マスタタスク・フィードバック -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeOtherUserContent</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- 健康・フィットネス — 睡眠スコア(音声・体動の生データは端末外へ送信しない) -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeHealth</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
	</array>

	<!-- アプリ自身のコードは required-reason API (UserDefaults等) を直接使用していない。
	     Firebase / TensorFlowLite は各SDK同梱のマニフェストで申告される -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array/>
</dict>
</plist>
